{
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/theme/:slug", "destination": "/theme.html" },
    { "source": "/map", "destination": "/map.html" },
    { "source": "/market-movers", "destination": "/market-movers.html" },
    { "source": "/infographic", "destination": "/infographic.html" },
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
